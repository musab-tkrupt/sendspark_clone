SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=Videos
SUPABASE_PATH_PREFIX=sendspark
FRONTEND_URL=http://localhost:3001
# Comma-separated browser origins allowed to call this API (include your Vercel URL in production).
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001
# Alias (same meaning as CORS_ALLOW_ORIGINS) if you already set this on Render:
# ALLOWED_ORIGINS=https://your-app.vercel.app
SCROLL_STATUS_STALE_SECONDS=120
ENABLE_CHATTERBOX=false