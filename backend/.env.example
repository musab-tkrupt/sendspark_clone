# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_STORAGE_BUCKET=Videos
SUPABASE_PATH_PREFIX=sendspark

# ElevenLabs Configuration (optional, for voice synthesis)
ELEVENLABS_API_KEY=your_api_key_here
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# CORS - comma-separated list of allowed frontend URLs
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Toggle Chatterbox model loading
# Set to false to skip local voice cloning and reduce memory when using ElevenLabs only.
ENABLE_CHATTERBOX=false

# Frontend URL (for generating shareable preview links)
FRONTEND_URL=http://localhost:3001